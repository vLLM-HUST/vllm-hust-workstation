# ======================================================
#  vllm-hust-workstation  —  私有 AI 工作站配置
# ======================================================
#  复制本文件为 .env 后修改，然后 docker compose up -d

# vllm-hust-gateway 的地址（OpenAI 兼容接口）
# 本地开发默认直连 localhost；Docker 场景再改成 host.docker.internal
# 若 8080 已被其他服务占用，可改成例如 http://localhost:18080
VLLM_HUST_BASE_URL=http://localhost:8080

# API Key（vllm-hust 在私有部署时通常不需要）
VLLM_HUST_API_KEY=not-required

# quickstart.sh / start.sh 默认会为本地地址自动拉起 vllm-hust-gateway
WORKSTATION_AUTO_START_GATEWAY=true

# 当本地 gateway 存在但不可推理时，是否允许 quickstart 自动重建为可用完整栈
WORKSTATION_AUTO_HEAL_GATEWAY=true

# 默认启动时，若本地已有健康服务但模型与 .env 不一致，是否仍强制切换到 .env 模型。
# 默认 false，避免因为旧配置误重启正在使用的本地服务。
WORKSTATION_ENFORCE_BOOTSTRAP_MODEL_ON_START=false

# quickstart 本地自启动所用的 bootstrap 模型（加速卡场景建议 7B 起步）
WORKSTATION_BOOTSTRAP_MODEL=Qwen/Qwen2.5-7B-Instruct

# 是否在直接执行 ./quickstart.sh 时优先进入交互式演示菜单
WORKSTATION_INTERACTIVE_LAUNCHER=true

# 是否在 quickstart 启动时显示交互式模型菜单（仅本地终端生效）
WORKSTATION_INTERACTIVE_MODEL_MENU=true

# quickstart 本地自启动后端；留空或 auto 时会按硬件自动识别（nvidia-smi→cuda, npu-smi→ascend）
WORKSTATION_BOOTSTRAP_BACKEND=auto

# 是否按本机硬件自动识别启动后端
WORKSTATION_AUTO_DETECT_BACKEND=true

# Ascend 本地自启动默认走轻量插件模式，避免在启动前尝试编译 custom kernels。
# 如需显式覆盖，可设置为 1。
WORKSTATION_ASCEND_COMPILE_CUSTOM_KERNELS=0

# 当本机缺少 node/npm 时，是否允许 quickstart 通过当前激活的 conda 环境自动安装 Node.js 20。
WORKSTATION_AUTO_INSTALL_NODE_WITH_CONDA=true

# 自动安装 Node.js 时使用的 conda 包规格。
WORKSTATION_NODEJS_CONDA_SPEC=nodejs>=20,<21

# vllm-hust 本地自启动时使用的 tool parser。
# 留空时会按模型自动选择：Qwen2.5/QwQ -> hermes，Qwen3-Coder -> qwen3_xml，Llama 3.2 -> pythonic，Llama 4 -> llama4_pythonic，其他默认 openai
# WORKSTATION_TOOL_CALL_PARSER=hermes

# 当 Hugging Face 不可达且当前模型未缓存时，是否自动回退到本地已有缓存模型。
WORKSTATION_AUTO_FALLBACK_TO_LOCAL_CACHE=true

# quickstart 本地 engine 端口（默认 gateway_port + 1；若与其他服务冲突可改成其他空闲端口）
WORKSTATION_ENGINE_PORT=8902

# 默认展示的模型 ID（仅在上游不可达时兜底显示）
DEFAULT_MODEL=Qwen2.5-7B-Instruct

# 后端类型标签（仅在上游未返回真实信息时兜底显示）
BACKEND_TYPE=AUTO

# 如需自行托管 gateway / engine，也可按需填写：
# VLLM_HUST_CP_ENGINE_HOST=127.0.0.1
# VLLM_HUST_CP_ENGINE_PORT=8902
# VLLM_HUST_CP_ENGINE_MODEL=sshleifer/tiny-gpt2
# VLLM_HUST_CP_ENGINE_ID=workstation-engine

# 是否允许聊天前执行联网搜索（true/false）
SEARCH_ENABLED=true

# 联网搜索最多返回多少条结果
SEARCH_MAX_RESULTS=5

# 联网搜索超时时间（毫秒）
SEARCH_TIMEOUT_MS=8000

# 工作站未显式传 generation 参数时的默认 max_tokens
WORKSTATION_DEFAULT_MAX_TOKENS=128

# EvoScientist 嵌入调用（workstation -> EvoSci CLI）
# 默认优先使用本机 EvoSci 命令；若 PATH 中不可见，会自动回退到 WORKSTATION_EVOSCI_WORKDIR 下的 `python -m EvoScientist`
# workstation 会为每次请求自动生成临时 EvoScientist 配置，并默认绑定到本地 vllm-hust OpenAI 兼容接口
# 如有多环境可手动指定完整路径
WORKSTATION_EVOSCI_BIN=EvoSci

# 可选：显式指定 EvoScientist 所使用的 Python（例如独立 conda 环境）
# WORKSTATION_EVOSCI_PYTHON_BIN=/home/shuhao/miniforge3/envs/EvoSci/bin/python

# EvoScientist 仓库路径（用于 --workdir）
WORKSTATION_EVOSCI_WORKDIR=/home/shuhao/EvoScientist

# 可选：覆盖 EvoScientist 所连接的 OpenAI 兼容后端；默认继承 VLLM_HUST_BASE_URL 并自动补齐 /v1
# WORKSTATION_EVOSCI_BASE_URL=http://localhost:8080/v1

# 可选：覆盖 EvoScientist 所使用的 API Key；默认继承 VLLM_HUST_API_KEY 或使用 not-required
# WORKSTATION_EVOSCI_API_KEY=not-required

# 可选：覆盖 EvoScientist 默认模型；若不设置，优先使用当前工作站模型，并自动对齐后端真实 served model id
# WORKSTATION_EVOSCI_MODEL=Qwen/Qwen2.5-7B-Instruct

# EvoScientist 单次调用超时（毫秒）
WORKSTATION_EVOSCI_TIMEOUT_MS=180000

# 模型库本地下载目录
MODEL_HUB_DIR=

# Hugging Face 镜像地址；workstation 默认建议使用镜像，避免官网不可达时直接回退离线缓存
HF_ENDPOINT=https://hf-mirror.com

# 可选：需要鉴权的模型下载令牌
HF_TOKEN=

# 前端监听端口（若 3000 已被占用可改成其他空闲端口）
APP_PORT=3000

# ── 白牌定制 ──────────────────────────────────────────
# 左上角品牌名
APP_BRAND_NAME=vLLM-HUST 工作站

# Logo URL（留空则显示默认 AI 图标）
# 支持 http/https URL 或 base64 data URI
APP_BRAND_LOGO=

# 主题色（Hex）
APP_ACCENT_COLOR=#6366f1

# 可选：限制允许嵌入 workstation 的页面来源。
# 例如：APP_FRAME_ANCESTORS=https://intellistream.github.io https://vllm-hust.example.com
# 留空则不额外设置 frame-ancestors 响应头。
APP_FRAME_ANCESTORS=

# 可选：systemd --user 常驻服务名；deploy 脚本默认使用该名字。
WORKSTATION_SYSTEMD_SERVICE_NAME=vllm-hust-workstation

# 可选：production runtime 目录；默认由 deploy 脚本写入仓库内的 .workstation-deploy/runtime
# WORKSTATION_DEPLOY_RUNTIME_DIR=/home/shuhao/vllm-hust-workstation/.workstation-deploy/runtime
