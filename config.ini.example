[sagellm]
base_url = http://localhost:8093
api_key = not-required
default_model = YourModelName
backend_type = NVIDIA A100 80GB PCIe
model_path = /path/to/your/model

[hub]
models_dir = ~/Downloads/sagellm-models
hf_endpoint = https://hf-mirror.com
hf_token =

[server]
port = 3000

[brand]
name = SageLLM 私有工作站
accent_color = #6366f1
logo =

[search]
# 是否启用联网搜索功能 (true/false)
enabled = true
# 搜索引擎 (当前仅支持 duckduckgo)
engine = duckduckgo
# 每次搜索最多返回几条结果 (1-10)
max_results = 5
# 搜索请求超时秒数
timeout_sec = 8
# 搜索区域/语言 (us-en 英文, cn-zh 中文)
region = cn-zh
